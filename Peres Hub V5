            if hum then hum.PlatformStand = true end
            for _,n in pairs({"FlyV","FlyG"}) do local o=hrp:FindFirstChild(n) if o then o:Destroy() end end
            local bv = Instance.new("BodyVelocity") bv.Name="FlyV" bv.MaxForce=Vector3.new(math.huge,math.huge,math.huge) bv.Velocity=Vector3.zero bv.Parent=hrp
