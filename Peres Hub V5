local function TemParede(o,d)
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {LocalPlayer.Character}
    rp.FilterType = Enum.RaycastFilterType.Exclude
    local r = workspace:Raycast(o, d-o, rp)
    if r then
        local ch = r.Instance:FindFirstAncestorOfClass("Model")
        if ch then for _,p in pairs(Players:GetPlayers()) do if p.Character==ch then return false end end end
        return true
    end
    return false
end

local function GetAlvo()
    local best, bestD = nil, _G.AFOV or 150
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local parte = _G.APART or "Head"
    for _,p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local target = p.Character:FindFirstChild(parte)
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if target and hum and hum.Health > 0 then
                local sp, on = Camera:WorldToViewportPoint(target.Position)
                if on then
                    local d = (Vector2.new(sp.X,sp.Y) - center).Magnitude
                    local ok = not _G.AWALL or not TemParede(Camera.CFrame.Position, target.Position)
                    if d < bestD and ok then bestD = d best = p end
                end
            end
        end
    end
    return best
end

RunService.RenderStepped:Connect(function()
    if not _G.AIM then return end
    local alvo = GetAlvo() if not alvo then return end
    local parte = _G.APART or "Head"
    local target = alvo.Character and alvo.Character:FindFirstChild(parte) if not target then return end
    local sp, on = Camera:WorldToViewportPoint(target.Position) if not on then return end
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    if (Vector2.new(sp.X,sp.Y)-center).Magnitude > (_G.AFOV or 150)*1.5 then return end
    Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Position), 1/(_G.ASMOOTH or 5))
end)

